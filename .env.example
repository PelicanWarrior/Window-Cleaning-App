VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_AUTH_REDIRECT_URL=http://localhost:5173

# GoCardless (Supabase Edge Function secrets, not Vite env)
# Sandbox:
# GOCARDLESS_ENV=sandbox
# GOCARDLESS_CLIENT_ID=your_sandbox_client_id
# GOCARDLESS_CLIENT_SECRET=your_sandbox_client_secret
# GOCARDLESS_WEBHOOK_ENDPOINT_SECRET=your_sandbox_webhook_secret
# Live:
# GOCARDLESS_ENV=live
# GOCARDLESS_CLIENT_ID=your_live_client_id
# GOCARDLESS_CLIENT_SECRET=your_live_client_secret
# GOCARDLESS_WEBHOOK_ENDPOINT_SECRET=your_live_webhook_secret
# GOCARDLESS_STATE_SECRET=your_random_state_secret

# Twilio master credentials for backend provisioning (Supabase Edge Function secrets, not Vite env)
# TWILIO_MASTER_ACCOUNT_SID=your_master_account_sid
# TWILIO_MASTER_AUTH_TOKEN=your_master_auth_token